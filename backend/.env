# Variáveis para o Banco de Dados PostgreSQL
# Usadas pelo contêiner 'adote-facil-postgres'
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=adote_facil
POSTGRES_CONTAINER_PORT=5433

# Variável de Conexão para o Backend (Prisma)
# Usada pelo contêiner 'adote-facil-backend' para se conectar ao banco
DATABASE_URL=postgresql://docker:docker@adote-facil-postgres:5432/adote_facil?schema=public
